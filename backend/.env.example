# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (GitHub-as-a-Database)
# Leave these empty to read/write local JSON files on your device.
# Set these in your local .env or Vercel dashboard to enable real-time cloud updates!
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_REPO=your_github_username/your_repository_name
GITHUB_BRANCH=main

# Authentication Secrets
JWT_SECRET=localsm_default_secret_key_987654321
JWT_EXPIRES_IN=7d

# Cloudinary Storage Configuration (Optional, falls back to local disk storage if empty)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Default Admin Account Setup (Will be auto-seeded on startup if database is empty)
ADMIN_EMAIL=admin@localsm.com
ADMIN_PASSWORD=Admin@12345
