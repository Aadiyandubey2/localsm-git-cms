{
    "services": {
        "frontend": {
            "root": "frontend",
            "framework": "vite"
        },
        "backend": {
            "root": "backend",
            "entrypoint": "src/server.js"
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": {
                "service": "backend"
            }
        },
        {
            "source": "/((?!api|uploads|assets|images|favicon.svg|vite.svg).*)",
            "destination": {
                "service": "frontend",
                "path": "/index.html"
            }
        },
        {
            "source": "/:path*",
            "destination": {
                "service": "frontend"
            }
        }
    ]
}
