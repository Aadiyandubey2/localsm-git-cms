{
    "services": {
        "frontend": {
            "root": "frontend",
            "framework": "vite"
        },
        "backend": {
            "root": "backend",
            "entrypoint": "api/index.js"
        }
    },
    "rewrites": [
        {
            "source": "/api/:path*",
            "destination": {
                "service": "backend"
            }
        },
        {
            "source": "/:path*",
            "destination": {
                "service": "frontend"
            }
        }
    ]
}
