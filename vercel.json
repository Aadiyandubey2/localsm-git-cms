{
  "version": 2, 
  "builds": [
    {
      "src": "backend/api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": "backend/data/*.json"
      }
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/sitemap.xml",
      "destination": "backend/api/index.js"
    },
    {
      "source": "/api/:path*",
      "destination": "backend/api/index.js"
    },
    {
      "source": "/uploads/:path*",
      "destination": "backend/uploads/:path*"
    },
    {
      "source": "/assets/:path*",
      "destination": "frontend/assets/:path*"
    },
    {
      "source": "/images/:path*",
      "destination": "frontend/images/:path*"
    },
    {
      "source": "/favicon.svg",
      "destination": "frontend/favicon.svg"
    },
    {
      "source": "/vite.svg",
      "destination": "frontend/vite.svg"
    },
    {
      "source": "/((?!api/|uploads/|assets/|images/|favicon.svg|vite.svg|sitemap.xml).*)",
      "destination": "frontend/index.html"
    }
  ]
}
