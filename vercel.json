{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "backend/api/index.js"
    },
    {
      "source": "/uploads/:path*",
      "destination": "backend/uploads/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "frontend/$1"
    }
  ]
}
